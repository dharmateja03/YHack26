{
  "name": "neosis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && rm -f tsconfig.tsbuildinfo && next dev",
    "dev:clean": "rm -rf .next && rm -f tsconfig.tsbuildinfo && next dev",
    "build": "next build",
    "start": "next start",
    "seed": "node scripts/seed-sqlite-demo.mjs --mode demo",
    "seed:demo": "node scripts/seed-sqlite-demo.mjs --mode demo",
    "seed:dummy": "npx ts-node scripts/seed-dummy.ts",
    "seed:full-demo": "node scripts/seed-sqlite-demo.mjs --mode full",
    "seed:org-tax": "npx ts-node scripts/seed-org-tax.ts",
    "sync:pinecone": "node scripts/sync-pinecone.mjs",
    "test": "jest",
    "test:dharma": "jest __tests__/dharma.test.ts",
    "test:keshav": "jest __tests__/keshav.test.ts",
    "test:veda": "jest __tests__/veda.test.ts",
    "test:sai": "jest __tests__/sai.test.ts"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "^3.5.0",
    "@elevenlabs/react": "^1.0.0",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.8.0",
    "date-fns": "^3.6.0",
    "dotenv": "^17.3.1",
    "next": "14.2.25",
    "openai": "^4.40.0",
    "react": "^18",
    "react-dom": "^18",
    "tailwindcss": "^3.4.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29",
    "@types/node": "^20",
    "@types/react": "^18",
    "jest": "^29",
    "jest-environment-node": "^29",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/__tests__/setup.ts"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@/lib/mongodb$": "<rootDir>/__mocks__/lib/mongodb.ts",
      "^@/lib/lava$": "<rootDir>/__mocks__/lib/lava.ts",
      "^@/lib/voyage$": "<rootDir>/__mocks__/lib/voyage.ts",
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
