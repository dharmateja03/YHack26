# ─── Neosis Environment Variables ───────────────────────────────

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/neosis?retryWrites=true&w=majority
MONGODB_DB=neosis

# Lava Gateway (routes all LLM calls — Claude, Groq, etc.)
LAVA_API_KEY=lava_your_key_here
LAVA_BASE_URL=https://api.lava.so/v1

# Voyage embeddings (used for vector memory)
VOYAGE_API_KEY=voyage_your_key_here

# Pinecone vector DB (used for semantic retrieval / root cause)
PINECONE_API_KEY=pcsk_your_key_here
PINECONE_INDEX_HOST=your-index-name-xxxx.svc.us-east-1-aws.pinecone.io
PINECONE_NAMESPACE=neosis

# Hermes Agent (optional delegate for agent-to-agent scheduling)
# Defaults to Lava for model calls; can also use local Hermes CLI.
HERMES_ENABLED=false
HERMES_TRANSPORT=auto
HERMES_LAVA_MODEL=gpt-5-chat-latest
HERMES_LAVA_AGENT_ID=neo-sched-hermes

# Optional Hermes CLI settings (used when HERMES_TRANSPORT=cli or auto fallback)
HERMES_COMMAND=hermes
HERMES_PROVIDER=anthropic
HERMES_MODEL=claude-sonnet-4-6
HERMES_TIMEOUT_MS=20000

# ElevenLabs (voice briefings)
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ElevenLabs Conversational AI (real-time duplex voice)
ELEVENLABS_CONVAI_AGENT_ID=agent_xxxxxxxxxxxxxxxxx
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=agent_xxxxxxxxxxxxxxxxx

# Auth0 AI (OAuth token vault — GitHub, Slack, Jira tokens per user)
AUTH0_SECRET=your_auth0_secret_min_32_chars
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret

# Local master account fallback (dev only).
# IMPORTANT: keep false when multiple people use the same dev server.
ENABLE_MASTER_FALLBACK=false
MASTER_USER_ID=master-user
MASTER_USER_NAME=Master User
MASTER_USER_EMAIL=master@yourcompany.com

# GitHub (via Auth0 OAuth — stored per user, used by PR agent)
GITHUB_TOKEN=ghp_fallback_token_for_dev

# Slack (via Auth0 OAuth)
SLACK_BOT_TOKEN=xoxb-your-slack-token

# Scheduler agent cc email for meeting invites
NEO_AGENT_EMAIL=neo-agent@yourcompany.com
NYLAS_WEBHOOK_SECRET=your_nylas_webhook_secret

# Next.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret
